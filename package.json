{
  "name": "sanction-api-telegram-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Telegram bot for file-backed Debarred lookups over OpenSanctions-derived data.",
  "scripts": {
    "dev": "tsx --env-file=.env.develop src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
